    "description": {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "As a user, I want to permanently delete all personal data associated with my account so that I have full control over my privacy."
            }
          ],
          "attrs": {
            "localId": "a872f264522e"
          }
        },
        {
          "type": "heading",
          "attrs": {
            "level": 3,
            "localId": "74370a2893c5"
          },
          "content": [
            {
              "type": "text",
              "text": "Acceptance Criteria"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "attrs": {
                "localId": "0ea2891e8854"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Given I am logged in, when I request data deletion, then I am shown a confirmation dialog that clearly states the action is irreversible."
                    }
                  ],
                  "attrs": {
                    "localId": "c06abd392c7e"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "b0a25bb68f27"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "After confirming, all personal data (profile, conversations, preferences) is deleted within 30 days."
                    }
                  ],
                  "attrs": {
                    "localId": "e7a4f8cb2198"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "47aa32976190"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "I receive an email confirmation once the deletion is complete."
                    }
                  ],
                  "attrs": {
                    "localId": "740106b0fc01"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "a44bfeb6acaf"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "I cannot log in with the deleted account after the deletion is processed."
                    }
                  ],
                  "attrs": {
                    "localId": "09dab80d9f78"
                  }
                }
              ]
            }
          ],
          "attrs": {
            "localId": "3d22e7b2b8a8"
          }
        }
      ]
    },
